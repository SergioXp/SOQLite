---
interface Props {
	title: string;
	description: string;
	icon?: string;
}

const { title, description } = Astro.props;
---

<div class="glass p-8 rounded-2xl flex flex-col gap-4 group hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
	<div class="w-12 h-12 rounded-xl bg-mauve/10 flex items-center justify-center text-mauve shrink-0">
		<slot name="icon">
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>
		</slot>
	</div>
	<div>
		<h3 class="font-outfit text-xl font-semibold text-white mb-2">{title}</h3>
		<p class="text-slate-400 leading-relaxed text-sm">
			{description}
		</p>
	</div>
</div>

---
interface Props {
	href?: string;
	variant?: "primary" | "secondary";
	className?: string;
}

const { href, variant = "primary", className = "" } = Astro.props;

const baseStyles = "inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold transition-all duration-300 ring-offset-2 focus:ring-2 disabled:opacity-50 disabled:pointer-events-none active:scale-95";
const variants = {
	primary: "bg-peach text-slate-950 hover:bg-[#ffc29d] ring-peach shadow-lg shadow-peach/20",
	secondary: "bg-white/5 text-white hover:bg-white/10 ring-white/20 border border-white/10 backdrop-blur-md",
};

const Tag = href ? "a" : "button";
---

<Tag {href} class:list={[baseStyles, variants[variant], className]}>
	<slot />
</Tag>

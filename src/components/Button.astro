---
interface Props {
	href?: string;
	variant?: "primary" | "secondary";
	className?: string;
}

const { href, variant = "primary", className = "" } = Astro.props;

const baseStyles = "inline-flex items-center justify-center px-8 py-4 rounded-xl font-bold transition-all duration-300 ring-offset-2 focus:ring-2 disabled:opacity-50 disabled:pointer-events-none active:scale-95 z-10 relative";
const variants = {
	primary: "bg-[#fab387] text-[#0b0b0e] hover:bg-[#ffc29d] ring-[#fab387] shadow-lg shadow-[#fab387]/20",
	secondary: "bg-white/5 text-white hover:bg-white/10 ring-white/20 border border-white/10 backdrop-blur-md",
};

const Tag = href ? "a" : "button";
---

<Tag {href} class:list={[baseStyles, variants[variant], className]}>
	<slot />
</Tag>

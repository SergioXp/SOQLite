---
import { SEO } from "astro-seo";
import Analytics from '@vercel/analytics/astro'
import "../styles/global.css";

interface Props {
	title: string;
	description: string;
	lang: "en" | "es";
}

const { title, description, lang } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<SEO
			title={title}
			description={description}
			canonical={canonicalURL.toString()}
			openGraph={{
				basic: {
					title: title,
					type: "website",
					image: "/images/hero.png",
				},
				optional: {
					description: description,
					locale: lang === "es" ? "es_ES" : "en_US",
					siteName: "SOQLite",
				},
			}}
			twitter={{
				card: "summary_large_image",
				site: "@soqlite",
				creator: "@soqlite",
				title: title,
				description: description,
				image: "/images/hero.png",
			}}
			extend={{
				// Add hrelang tags
				link: [
					{ rel: "alternate", hreflang: "en", href: new URL("/", Astro.site).toString() },
					{ rel: "alternate", hreflang: "es", href: new URL("/es", Astro.site).toString() },
					{ rel: "alternate", hreflang: "x-default", href: new URL("/", Astro.site).toString() },
				],
			}}
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0b0b0e] text-slate-200 antialiased selection:bg-peach/30 selection:text-peach font-inter">
		<slot />
		<Analytics />
		<footer class="py-12 border-t border-white/5 bg-black/20 backdrop-blur-xl">
			<div class="max-row px-6 text-center">
				<p class="text-slate-500 text-sm">
					&copy; {new Date().getFullYear()} SOQLite. Created with &hearts; by <a href="mailto:sergiogonzalezhidalgo@gmail.com" class="text-slate-300 hover:text-white transition-colors">SergioXp</a>
				</p>
			</div>
		</footer>

		<script is:inline>
			async function updateVersion() {
				const repo = "SergioXp/SOQLite";
				try {
					const response = await fetch(`https://api.github.com/repos/${repo}/releases/latest`);
					const data = await response.json();
					const version = data.tag_name;
					if (version) {
						// Update Pill
						document.querySelectorAll('.version-pill').forEach(el => {
							const text = document.documentElement.lang === 'es' ? ' ya disponible' : ' is here';
							const tech = ' with Rust & React 19';
							el.innerHTML = `<span class="w-2 h-2 rounded-full bg-mauve animate-pulse"></span> ${version}${tech}${text}`;
						});
						// Update Buttons
						document.querySelectorAll('.download-btn').forEach(el => {
							const isEn = !el.textContent.includes('Descargar');
							if (el.classList.contains('text-xl')) {
								el.textContent = isEn ? `Download ${version} now` : `Descargar ${version} ya`;
							} else {
								el.textContent = isEn ? `Download for Free (${version})` : `Descargar Gratis (${version})`;
							}
						});
					}
				} catch (e) {
					// Silicon Valley fail silently style
				}
			}
			updateVersion();
		</script>
	</body>
</html>

<style is:global>
	:root {
		--mauve: #cba6f7;
		--peach: #fab387;
		--lavender: #b4befe;
		--surface0: #313244;
	}
	
	.font-outfit { font-family: 'Outfit', sans-serif; }
	.font-mono { font-family: 'JetBrains Mono', monospace; }
	
	.max-row {
		max-width: 1200px;
		margin-left: auto;
		margin-right: auto;
	}

	.glass {
		background: rgba(255, 255, 255, 0.03);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}

	.text-gradient {
		background: linear-gradient(135deg, var(--mauve), var(--peach));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	html {
		scroll-behavior: smooth;
	}
</style>
